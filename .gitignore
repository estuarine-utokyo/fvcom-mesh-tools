# Python
__pycache__/
*.py[cod]
*$py.class
*.so
build/
dist/
*.egg-info/
*.egg

# Virtual envs
.venv/
venv/
env/

# IDE
.idea/
.vscode/
*.swp

# Test/lint caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/

# Notebooks
.ipynb_checkpoints/

# Generated outputs
outputs/
figures/
*.html

# HPC scheduler artifacts (PJM/Slurm: <jobname>.<jobid>.{out,err,stats})
*.[0-9]*.out
*.[0-9]*.err
*.[0-9]*.stats
# PJM nodeinfo / per-job temp files written into the submission CWD
.d[0-9]*
.d[0-9]*_nodeinfo

# Core dumps (e.g. from third-party native libraries)
core
core.*

# Mesh data — large; do not commit (allowed under tests/fixtures/)
*.14
*.nc
!tests/fixtures/**/*.14
!tests/fixtures/**/*.nc

# Local data dirs
data/

# Secrets
.env
.env.*
!.env.example

# OS
.DS_Store
Thumbs.db

# Session-local handover notes (per-session briefing, not part of project history)
HANDOVER.md

# Claude Code per-session runtime state
.claude/
