# Add GDAL netCDF driver to oceanmesh-bench so rasterio.open() can
# read .nc DEMs (the bench's DEM is the Tokyo Bay CF NetCDF).

set -euo pipefail
"${HOME}/mambaforge/bin/mamba" install -y -n oceanmesh-bench -c conda-forge libgdal-netcdf
