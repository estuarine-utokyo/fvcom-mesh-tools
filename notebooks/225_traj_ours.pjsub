#!/bin/bash
#PJM -L rscgrp=a-batch
#PJM -L vnode=1
#PJM -L vnode-core=32
#PJM -L elapse=01:30:00
#PJM -j
#PJM -X
#PJM -N fvcm-poc225
set -euo pipefail
export OMP_NUM_THREADS=1 OPENBLAS_NUM_THREADS=1 MKL_NUM_THREADS=1
export OM_TRACE_SCALE=1
cd "${HOME}/Github/fvcom-mesh-tools"
for s in 1 2; do
  echo "===SEED $s"
  JBAY_SEED=$s JBAY_RAW_ONLY=1 "${HOME}/mambaforge/envs/oceanmesh-bench/bin/python" notebooks/211_jbay.py 2>&1 | grep -E "\[traj\]|\[jbay\]|iter .*NP=" | awk 'NR%1==0'
done
