#!/bin/bash
#PJM -L rscgrp=a-batch
#PJM -L vnode=1
#PJM -L vnode-core=4
#PJM -L elapse=02:00:00
#PJM -j
#PJM -X
#PJM -N fvcm-poc41

# PoC #41: Phase H v1 end-to-end validation.
# Also re-runs PoC #40 (with bug fix in _ring_by_node) to refresh
# the dry-run summary numbers.

set -euo pipefail

export OMP_NUM_THREADS=4
export OPENBLAS_NUM_THREADS=4
export MKL_NUM_THREADS=4

: "${HOME:?HOME not set}"

source "${HOME}/mambaforge/etc/profile.d/conda.sh"
conda activate oceanmesh-bench

cd "${HOME}/Github/fvcom-mesh-tools"

echo "=== Re-run PoC #40 with the _ring_by_node bug fix ==="
python notebooks/40_phase_h_dry_run_poc.py

echo
echo "=== PoC #41: Phase H v1 ==="
python notebooks/41_phase_h_v1_validation_poc.py
