#!/bin/bash
#PJM -L rscgrp=a-batch
#PJM -L vnode=1
#PJM -L vnode-core=2
#PJM -L elapse=06:00:00
#PJM -j
#PJM -X
#PJM -N fvcm-poc45

# PoC #45: Phase H v4 end-to-end (2-step lookahead) on PoC #19 input.
# Pass A + Pass B + Pass C (lookahead) with v3 coastline projection.
# Compares to PoC #43 (v3) A/B.

set -euo pipefail

export OMP_NUM_THREADS=2
export OPENBLAS_NUM_THREADS=2
export MKL_NUM_THREADS=2
export PYTHONUNBUFFERED=1

: "${HOME:?HOME not set}"

source "${HOME}/mambaforge/etc/profile.d/conda.sh"
conda activate oceanmesh-bench

cd "${HOME}/Github/fvcom-mesh-tools"

python -u notebooks/45_phase_h_v4_validation_poc.py
